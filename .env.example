# Cole no painel do Vercel (Settings > Environment Variables), não neste arquivo.

# Connection string do Neon (Dashboard do projeto Neon > Connect)
DATABASE_URL=postgres://usuario:senha@ep-exemplo.neon.tech/neondb?sslmode=require

# String aleatória longa, gere com: openssl rand -hex 32
SESSION_SECRET=

# 32 bytes em hexadecimal (64 caracteres), gere com: openssl rand -hex 32
ENCRYPTION_KEY=
